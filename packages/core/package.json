{
  "name": "@avodado/core",
  "version": "0.0.2",
  "description": "Avodado core: parser, block schemas, validation, and reference resolver.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdiejim/avodado.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/jdiejim/avodado#readme",
  "bugs": "https://github.com/jdiejim/avodado/issues",
  "keywords": [
    "avodado",
    "documentation",
    "docs-as-code",
    "markdown",
    "yaml",
    "diagrams",
    "parser",
    "schema",
    "zod",
    "validation"
  ],
  "engines": {
    "node": ">=20"
  }
}
