{
  "name": "avodado",
  "displayName": "Avodado",
  "description": "Live preview + validation for Avodado documentation (Markdown with typed YAML blocks).",
  "version": "0.0.1",
  "publisher": "avodado",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "icon": "icon.png",
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/jdiejim/avodado.git",
    "directory": "packages/vscode-extension"
  },
  "homepage": "https://github.com/jdiejim/avodado/tree/main/packages/vscode-extension",
  "bugs": {
    "url": "https://github.com/jdiejim/avodado/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "avodado",
    "documentation",
    "diagrams",
    "markdown"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "workspaceContains:avodado.config.json",
    "workspaceContains:avodado.config.yml",
    "workspaceContains:.avodado/skill/SKILL.md"
  ],
  "contributes": {
    "commands": [
      {
        "command": "avodado.showPreview",
        "title": "Avodado: Show Preview to the Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "avodado.cycleTheme",
        "title": "Avodado: Cycle Preview Theme"
      },
      {
        "command": "avodado.checkAll",
        "title": "Avodado: Validate All Documents"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "avodado.showPreview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Avodado",
      "properties": {
        "avodado.theme": {
          "type": "string",
          "enum": [
            "textbook",
            "minimal",
            "teal",
            "slate"
          ],
          "default": "textbook",
          "description": "Theme for the preview pane."
        },
        "avodado.validate.glob": {
          "type": "string",
          "default": "docs/**/*.md",
          "description": "Glob for documents that should be validated as Avodado docs (relative to the workspace root)."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "tsup",
    "package": "tsup && vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "dependencies": {},
  "devDependencies": {
    "@avodado/core": "workspace:*",
    "@avodado/render": "workspace:*",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.2.1",
    "ovsx": "^0.10.1"
  }
}
