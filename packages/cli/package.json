{
  "name": "@avodado/cli",
  "version": "0.14.0",
  "description": "Avodado CLI — author, validate, render, and export typed Markdown docs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/bin.js",
  "bin": {
    "avo": "./dist/bin.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && chmod +x dist/bin.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@avodado/core": "workspace:*",
    "@avodado/export": "workspace:*",
    "@avodado/render": "workspace:*",
    "@avodado/sync": "workspace:*",
    "cfonts": "^3.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-table": "^3.1.0",
    "jiti": "^2.4.2",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "ink-testing-library": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdiejim/avodado.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/jdiejim/avodado#readme",
  "bugs": "https://github.com/jdiejim/avodado/issues",
  "keywords": [
    "avodado",
    "documentation",
    "docs-as-code",
    "markdown",
    "cli",
    "diagrams",
    "developer-tools"
  ],
  "engines": {
    "node": ">=20"
  }
}
