{
  "name": "@avodado/sync",
  "version": "0.0.6",
  "description": "Import external sources (OpenAPI, SQL DDL) into Avodado documents.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@avodado/core": "workspace:*",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdiejim/avodado.git",
    "directory": "packages/sync"
  },
  "homepage": "https://github.com/jdiejim/avodado#readme",
  "bugs": "https://github.com/jdiejim/avodado/issues",
  "keywords": [
    "avodado",
    "documentation",
    "docs-as-code",
    "markdown",
    "openapi",
    "codegen"
  ],
  "engines": {
    "node": ">=20"
  }
}
